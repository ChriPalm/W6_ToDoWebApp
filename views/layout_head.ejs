<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>W:6 Providör</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    :root { --w6-dark: #1a1a2e; --w6-accent: #c9a84c; --w6-accent-hover: #b8933a; }
    body { background: #f4f1eb; font-family: 'Segoe UI', system-ui, sans-serif; }
    .navbar { background: var(--w6-dark) !important; }
    .navbar-brand, .nav-link { color: #fff !important; }
    .nav-link:hover { color: var(--w6-accent) !important; }
    .btn-w6 { background: var(--w6-accent); color: #fff; border: none; }
    .btn-w6:hover { background: var(--w6-accent-hover); color: #fff; }
    .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
    .badge-role { background: var(--w6-dark); color: var(--w6-accent); }
    .phase-header { background: var(--w6-dark); color: var(--w6-accent); padding: .5rem 1rem; border-radius: .375rem; }
    .checklist-done { text-decoration: line-through; opacity: .6; }
    .stock-low { color: #dc3545; font-weight: bold; }
    .stock-ok { color: #198754; }
    footer { color: #888; font-size: .85rem; margin-top: 3rem; padding: 1rem 0; text-align: center; }
  </style>
</head>
<body>
<% if (currentUser) { %>
<nav class="navbar navbar-dark navbar-expand-lg mb-4">
  <div class="container">
    <a class="navbar-brand fw-bold" href="<%= BASE %>/">W:6</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="nav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="<%= BASE %>/">Hem</a></li>
        <li class="nav-item"><a class="nav-link" href="<%= BASE %>/schema">Schema</a></li>
        <li class="nav-item"><a class="nav-link" href="<%= BASE %>/swaps">Byten</a></li>
        <li class="nav-item"><a class="nav-link" href="<%= BASE %>/lager">Lager</a></li>
      </ul>
      <span class="navbar-text text-light me-3">
        <%= currentUser.display_name %> <span class="badge badge-role"><%= currentUser.role %></span>
      </span>
      <a class="btn btn-outline-light btn-sm" href="<%= BASE %>/logout">Logga ut</a>
    </div>
  </div>
</nav>
<% } %>
<div class="container">
<% if (flash) { %>
  <div class="alert alert-<%= flash.type %> alert-dismissible fade show" role="alert">
    <%= flash.message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
