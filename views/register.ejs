<%- include('layout_head') %>
<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card p-4">
      <h2 class="text-center mb-4">Skapa konto</h2>
      <form method="post" action="/register">
        <div class="mb-3">
          <label class="form-label">Användarnamn</label>
          <input type="text" name="username" class="form-control" required autofocus>
        </div>
        <div class="mb-3">
          <label class="form-label">Visningsnamn</label>
          <input type="text" name="display_name" class="form-control" required placeholder="Förnamn Efternamn">
        </div>
        <div class="mb-3">
          <label class="form-label">Lösenord</label>
          <input type="password" name="password" class="form-control" required>
        </div>
        <button class="btn btn-w6 w-100">Registrera</button>
      </form>
      <p class="text-center mt-3 mb-0">
        <a href="/login">Har redan konto? Logga in</a>
      </p>
    </div>
  </div>
</div>
<%- include('layout_foot') %>
