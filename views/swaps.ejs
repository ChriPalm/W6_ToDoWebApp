<%- include('layout_head') %>
<h2 class="mb-4">Passbyten</h2>

<% if (openSwaps.length) { %>
<div class="card p-3 mb-4">
  <h4>Öppna byten — ta ett pass!</h4>
  <ul class="list-group list-group-flush">
  <% for (const sr of openSwaps) { %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <div>
        <strong><%= sr.requester_name %></strong> söker ersättare för
        <em><%= sr.assignment_role %></em> den <%= formatDate(sr.date) %>
        <% if (sr.message) { %><br><small class="text-muted"><%= sr.message %></small><% } %>
      </div>
      <% if (sr.requester_id !== currentUser.id) { %>
      <form method="post" action="/swap/respond/<%= sr.id %>">
        <button name="action" value="take" class="btn btn-w6 btn-sm">Jag tar det!</button>
      </form>
      <% } %>
    </li>
  <% } %>
  </ul>
</div>
<% } %>

<% if (myIncoming.length) { %>
<div class="card p-3 mb-4">
  <h4>Förfrågningar till dig</h4>
  <ul class="list-group list-group-flush">
  <% for (const sr of myIncoming) { %>
    <li class="list-group-item">
      <strong><%= sr.requester_name %></strong> vill byta
      <em><%= sr.assignment_role %></em> (<%= formatDateShort(sr.date) %>)
      <% if (sr.message) { %><br><small class="text-muted"><%= sr.message %></small><% } %>
      <form method="post" action="/swap/respond/<%= sr.id %>" class="mt-2">
        <button name="action" value="accept" class="btn btn-sm btn-success">Acceptera</button>
        <button name="action" value="decline" class="btn btn-sm btn-outline-danger">Neka</button>
      </form>
    </li>
  <% } %>
  </ul>
</div>
<% } %>

<div class="card p-3">
  <h4>Mina skickade förfrågningar</h4>
  <% if (myOutgoing.length) { %>
  <ul class="list-group list-group-flush">
  <% for (const sr of myOutgoing) { %>
    <li class="list-group-item d-flex justify-content-between align-items-center">
      <div>
        <em><%= sr.assignment_role %></em> — <%= formatDateShort(sr.date) %>
        <% if (sr.target_name) { %> till <%= sr.target_name %><% } else { %> (öppen)<% } %>
      </div>
      <span class="badge <%= sr.status === 'accepted' ? 'bg-success' : sr.status === 'declined' ? 'bg-danger' : 'bg-warning text-dark' %>">
        <%= sr.status.charAt(0).toUpperCase() + sr.status.slice(1) %>
      </span>
    </li>
  <% } %>
  </ul>
  <% } else { %>
  <p class="text-muted">Du har inga skickade bytesförfrågningar.</p>
  <% } %>
</div>
<%- include('layout_foot') %>
