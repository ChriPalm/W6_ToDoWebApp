<%- include('layout_head') %>
<h2 class="mb-4">Lagerstatus</h2>

<% for (const [category, items] of Object.entries(categories)) { %>
<div class="card mb-3">
  <div class="card-header fw-bold"><%= category %></div>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead><tr><th>Artikel</th><th>Saldo</th><th>Enhet</th><th>Uppdatera</th></tr></thead>
      <tbody>
      <% for (const item of items) { %>
        <tr>
          <td><%= item.name %></td>
          <td class="<%= item.stock <= 1 ? 'stock-low' : 'stock-ok' %>"><%= item.stock %></td>
          <td><%= item.unit %></td>
          <td>
            <form method="post" action="<%= BASE %>/lager/update/<%= item.id %>" class="d-flex" style="max-width:160px">
              <input type="number" name="stock" step="0.5" min="0" value="<%= item.stock %>" class="form-control form-control-sm me-1">
              <button class="btn btn-sm btn-outline-secondary">Spara</button>
            </form>
          </td>
        </tr>
      <% } %>
      </tbody>
    </table>
  </div>
</div>
<% } %>
<%- include('layout_foot') %>
