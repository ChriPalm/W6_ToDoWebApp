<%- include('layout_head') %>
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card p-4">
      <h3>Byt pass</h3>
      <p>
        Du vill byta ditt pass som <strong><%= assignment.role %></strong>
        den <strong><%= formatDate(assignment.date) %></strong>.
      </p>
      <form method="post" action="/swap/request/<%= assignment.id %>">
        <div class="mb-3">
          <label class="form-label">Vem vill du byta med?</label>
          <select name="target_id" class="form-select">
            <option value="">Öppen förfrågan (vem som helst kan ta det)</option>
            <% for (const u of users) { %>
            <option value="<%= u.id %>"><%= u.display_name %> (<%= u.role %>)</option>
            <% } %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Meddelande (valfritt)</label>
          <textarea name="message" class="form-control" rows="2" placeholder="T.ex. anledning till byte..."></textarea>
        </div>
        <button class="btn btn-w6">Skicka förfrågan</button>
        <a href="/meeting/<%= assignment.meeting_id %>" class="btn btn-outline-secondary">Avbryt</a>
      </form>
    </div>
  </div>
</div>
<%- include('layout_foot') %>
